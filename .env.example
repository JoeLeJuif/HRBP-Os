# HRBP OS — environment variables.
# Set these in Vercel (Project → Settings → Environment Variables) and locally
# if testing. Never commit real values; this file is a template only.

# ── Client-side (injected at build time by build.js via esbuild --define) ─────
# The publishable key is safe to ship to the browser; never put the
# service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── Server-side (read at runtime by api/*.js on Vercel) ──────────────────────
# Required by /api/chat to call the Anthropic Messages API.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase server-side credentials. The api/chat.js handler falls back to the
# VITE_* vars above when these are not set, so only define them explicitly if
# you want server/client to diverge. Use the anon/publishable key only — never
# the service_role key here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here
# Alternate name accepted by api/chat.js:
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Service role key — REQUIRED by /api/signup and /api/stripe-webhook. Bypasses
# RLS, so must NEVER be shipped to the browser. Vercel: set as a server-only
# environment variable. Do not prefix with VITE_ (build.js does not inject it).
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_key_here

# Allowed origin for /api/chat CORS. Defaults to https://hrbp-os.vercel.app if
# unset. Override for preview deployments or a custom domain.
HRBPOS_ORIGIN=https://hrbp-os.vercel.app

# ── Stripe (Sprint 3 — placeholders only, NOT wired yet) ─────────────────────
# Server-side: keep secret. Used by the future /api/stripe/* handlers and the
# Stripe webhook receiver. Never expose the secret key to the browser.
STRIPE_SECRET_KEY=sk_test_placeholder_replace_me
# Webhook signing secret — Stripe dashboard → Developers → Webhooks → Reveal.
STRIPE_WEBHOOK_SECRET=whsec_placeholder_replace_me
# Client-side: safe to ship to the browser via build-time --define. Used by
# Stripe.js / Checkout on the billing page.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_replace_me

# ── Notes ─────────────────────────────────────────────────────────────────────
# - React / ReactDOM are loaded from unpkg.com at runtime (see public/index.html).
#   The CSP allow-lists https://unpkg.com under script-src for that reason.
#   Bundling them into public/app.js would require adding react/react-dom to
#   package.json and dropping --external:react[-dom] from build.js — deferred
#   to a later sprint to keep the bundle small and the cached CDN copy in play.
